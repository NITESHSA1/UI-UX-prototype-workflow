pageType: chapter
background:
  type: image
  src: "https://kimi-web-img.moonshot.cn/img/cdn.prod.website-files.com/1c005df50ec0aaa12707418471b8cad2d5f3bd3c.webp"
  fit: {mode: cover}
  mask:
    type: gradient
    gradientType: linear
    angle: 0
    stops:
      - {position: 0, color: "#0F0F1AE8"}
      - {position: 0.6, color: "#0F0F1ACC"}
      - {position: 1, color: "#0F0F1A99"}
elements:
  - elementId: chapter1-watermark
    elementType: text
    bounds: [60, 120, 400, 160]
    opacity: 0.08
    content:
      fontSize: 140
      fontFamily: "Liter"
      color: "$light"
      align: [left, top]
      wrap: false
      text: |
        <p>01</p>

  - elementId: chapter1-label
    elementType: text
    bounds: [60, 280, 200, 22]
    content:
      fontSize: 14
      fontFamily: "Liter"
      color: "$accent"
      letterSpacing: 3
      align: [left, middle]
      wrap: false
      text: |
        <p>CHAPTER ONE</p>

  - elementId: chapter1-accent-line
    elementType: shape
    bounds: [60, 320, 60, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: chapter1-title
    elementType: text
    bounds: [60, 340, 780, 55]
    content:
      fontSize: 38
      fontFamily: "Liter"
      color: "$light"
      letterSpacing: 3
      align: [left, middle]
      wrap: false
      text: |
        <p>FROM WIREFRAMES TO PROTOTYPES</p>

  - elementId: chapter1-subtitle
    elementType: text
    bounds: [60, 410, 600, 70]
    content:
      fontSize: 18
      fontFamily: "QuattrocentoSans"
      color: "#F9F8F6AA"
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>Transform static designs into clickable, interactive experiences using industry-standard tools</p>
