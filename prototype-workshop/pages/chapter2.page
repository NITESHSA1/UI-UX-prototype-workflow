pageType: chapter
background:
  type: image
  src: "https://kimi-web-img.moonshot.cn/img/miro.medium.com/a454417113d5588aa0cf892a7146c91090f7b376.png"
  fit: {mode: cover}
  mask:
    type: gradient
    gradientType: linear
    angle: 0
    stops:
      - {position: 0, color: "#0F0F1AE8"}
      - {position: 0.6, color: "#0F0F1ACC"}
      - {position: 1, color: "#0F0F1A99"}
elements:
  - elementId: ch2-watermark
    elementType: text
    bounds: [60, 120, 400, 160]
    opacity: 0.08
    content:
      fontSize: 140
      fontFamily: "Liter"
      color: "$light"
      align: [left, top]
      wrap: false
      text: |
        <p>02</p>

  - elementId: ch2-label
    elementType: text
    bounds: [60, 280, 200, 22]
    content:
      fontSize: 14
      fontFamily: "Liter"
      color: "$accent"
      letterSpacing: 3
      align: [left, middle]
      wrap: false
      text: |
        <p>CHAPTER TWO</p>

  - elementId: ch2-accent-line
    elementType: shape
    bounds: [60, 320, 60, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: ch2-title
    elementType: text
    bounds: [60, 340, 700, 55]
    content:
      fontSize: 38
      fontFamily: "Liter"
      color: "$light"
      letterSpacing: 3
      align: [left, middle]
      wrap: false
      text: |
        <p>BRINGING PROTOTYPES TO LIFE</p>

  - elementId: ch2-subtitle
    elementType: text
    bounds: [60, 410, 600, 70]
    content:
      fontSize: 18
      fontFamily: "QuattrocentoSans"
      color: "#F9F8F6AA"
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>Add motion, transitions, and realistic navigation to create believable user experiences</p>
